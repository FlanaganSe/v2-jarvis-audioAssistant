{
  "name": "v2-jarvis-audio",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server/server.ts",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:client && tsc",
    "start": "node dist/server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ && prettier --check src/ public/",
    "lint:fix": "eslint --fix src/ && prettier --write src/ public/",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "npm run typecheck --prefix client",
    "typecheck:all": "npm run typecheck && npm run typecheck:client",
    "postinstall": "npm install --prefix client",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "eval": "agent-eval-kit run --mode replay",
    "eval:record": "agent-eval-kit record"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "postgres": "^3.4.8",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "agent-eval-kit": "^0.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "concurrently": "^9.0.0",
    "vitest": "^3.0.0"
  }
}
