# === Required for M1: Voice Spike ===
OPENAI_API_KEY=           # OpenAI API key with Realtime API access
PORT=3000                 # Server port (Railway provides this automatically)

# === Required for M2: Persistence + Memory ===
DATABASE_URL=             # PostgreSQL connection string (e.g., postgresql://user:pass@localhost:5432/jarvis)

# === Required for M3: Tools + Evidence ===
GITHUB_TOKEN=             # Fine-grained GitHub PAT with read-only repo access

# === Set automatically by Railway in production ===
NODE_ENV=development
