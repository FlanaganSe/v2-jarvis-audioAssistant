# === Required ===
OPENAI_API_KEY=           # OpenAI API key with Realtime API access
PORT=3000                 # Server port (Railway provides this automatically)

# === Optional: enables persistence, recall, and full tool set ===
DATABASE_URL=             # PostgreSQL connection string (e.g., postgresql://user:pass@localhost:5432/jarvis)

# === Optional: enables GitHub tool ===
GITHUB_TOKEN=             # Fine-grained GitHub PAT with read-only repo access

# === Set automatically by Railway in production ===
NODE_ENV=development

# Note: Weather uses Open-Meteo (https://open-meteo.com/) — no API key needed.
# Without DATABASE_URL, the server runs in echo-only mode (voice works, tools limited).
# Without GITHUB_TOKEN, everything works except the GitHub tool.
